# Your Redis 8.4+ endpoint (Cloud, VPC, etc.) — this repo does not start Redis.
REDIS_URL=redis://:password@your-redis-host:10000/0

# docker compose (pull-only): image on Docker Hub — override tag as needed.
DOCKER_IMAGE=gacerioni/gabs-sku-hybridsearch-redis:latest

INDEX_NAME=idx:food_listing
KEY_PREFIX=dish:

RRF_K=10
# RRF WINDOW (0 = omit WINDOW token; use only CONSTANT).
RRF_WINDOW=40
HYBRID_KNN=120
# Optional VSIM KNN EF_RUNTIME (empty = omit).
HYBRID_KNN_EF_RUNTIME=128
DEFAULT_SEARCH_LIMIT=20
USER_GEO_DEFAULT_RADIUS_KM=15

FTS_WEIGHT=0.5
VSS_WEIGHT=0.5

# Multilingual E5-large (1024d). After changing model/dim: DROP INDEX + re-seed.
# True 2048-d multilingual dense in Sentence-Transformers is uncommon; this is a strong OSS default.
EMBEDDING_MODEL=intfloat/multilingual-e5-large
EMBEDDING_DIM=1024
EMBED_DEVICE=cpu
EMBEDDING_WRITE_MODE=all
# query:/passage: prefixes for E5. Use "none" for other encoders that break on prefixes.
EMBEDDING_INSTRUCTION_MODE=e5

# VECTOR index: hnsw | flat
VECTOR_INDEX_TYPE=hnsw
HNSW_M=24
HNSW_EF_CONSTRUCTION=256
# 0 = auto INITIAL_CAP max(100000, SEED_TARGET_DISHES)
HNSW_INITIAL_CAP=0

# Demo catalog size (500k is the contract; use a smaller count only for local dev).
SEED_TARGET_DISHES=500000
SEED_EMBED_SAMPLE_PCT=15
INGEST_PIPELINE_CHUNK_SIZE=1000

AUTOCOMPLETE_KEY=ac:food_dishes
AUTOCOMPLETE_MAX_SUGGESTIONS=20000
AUTOCOMPLETE_MIN_TITLE_LEN=3

API_HOST=0.0.0.0
API_PORT=8686

ALLOW_INDEX_REBUILD=false

FUZZY_FALLBACK_ON_MISS=true
FUZZY_MIN_TOKEN_LEN=4
